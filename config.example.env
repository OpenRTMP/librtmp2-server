# librtmp2-server configuration
# Copy this file to config.env and adjust as needed.
# The API token is generated automatically on first startup — do not set it here.

# RTMP listener address
RTMP_BIND=0.0.0.0:1935

# Maximum concurrent RTMP connections
RTMP_MAX_CONNECTIONS=100

# RTMP chunk size in bytes
RTMP_CHUNK_SIZE=4096

# RTMPS (TLS) — disabled by default
TLS_ENABLED=false
TLS_CERT_FILE=/etc/librtmp2-server/fullchain.pem
TLS_KEY_FILE=/etc/librtmp2-server/privkey.pem

# HTTP API and UI listener address
HTTP_BIND=0.0.0.0:8080

# Require a stream key to publish (recommended)
REQUIRE_STREAM_KEY=true

# Path to the web UI directory
WEB_ROOT=./web

# Log level: 0=error 1=warn 2=info 3=debug
LOG_LEVEL=2

# Log file path (empty = stderr only)
LOG_FILE=
